{
  "id": "memory-agentcore",
  "name": "AgentCore Memory",
  "description": "Enterprise shared memory via Amazon Bedrock AgentCore Memory. Provides cloud-based shared memory with governance, managed extraction, and episodic learning.",
  "version": "0.1.1",
  "kind": "general",
  "entry": "src/index.ts",
  "skills": ["skills/agentcore-memory-validation", "skills/agentcore-memory-guide"],
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable/disable the plugin"
      },
      "memoryId": {
        "type": "string",
        "description": "AgentCore Memory resource ID (e.g. MEMORY1234567890)"
      },
      "awsRegion": {
        "type": "string",
        "default": "us-east-1",
        "description": "AWS region"
      },
      "awsProfile": {
        "type": "string",
        "description": "Named AWS credential profile"
      },
      "strategies": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["SEMANTIC", "USER_PREFERENCE", "EPISODIC", "SUMMARY"],
        "description": "Active extraction strategies"
      },
      "autoRecallTopK": {
        "type": "number",
        "default": 5,
        "description": "Memories to inject before each turn (0=disabled)"
      },
      "autoCaptureEnabled": {
        "type": "boolean",
        "default": true,
        "description": "Auto-capture after each agent run"
      },
      "autoCaptureMinLength": {
        "type": "number",
        "default": 30,
        "description": "Min combined message length for capture"
      },
      "noiseFilterEnabled": {
        "type": "boolean",
        "default": true,
        "description": "Filter greetings/heartbeats before capture"
      },
      "adaptiveRetrievalEnabled": {
        "type": "boolean",
        "default": true,
        "description": "Skip trivial query retrieval"
      },
      "namespaceMode": {
        "type": "string",
        "enum": ["per-agent", "per-user", "shared", "custom"],
        "default": "per-agent",
        "description": "Namespace isolation mode"
      },
      "eventExpiryDays": {
        "type": "number",
        "default": 90,
        "description": "Short-term event retention days"
      },
      "showScores": {
        "type": "boolean",
        "default": false,
        "description": "Include similarity scores in recalled memories"
      },
      "scoreGapEnabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable score gap detection to filter low-relevance results"
      },
      "scoreGapMultiplier": {
        "type": "number",
        "default": 2.0,
        "description": "Gap sensitivity multiplier. Higher = more lenient, lower = stricter"
      },
      "minScoreFloor": {
        "type": "number",
        "default": 0.0,
        "description": "Absolute minimum score threshold (0.0 = disabled)"
      },
      "noisePatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "User-defined regex patterns to treat as noise (e.g. [\"^はい$\", \"^Build succeeded\"])"
      },
      "bypassPatterns": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "User-defined regex patterns to bypass noise filter (e.g. [\"^Error:\"])"
      },
      "statsCacheTtlMs": {
        "type": "number",
        "default": 300000,
        "description": "Stats cache TTL in milliseconds (default: 5 minutes)"
      },
      "fileSyncEnabled": {
        "type": "boolean",
        "default": true,
        "description": "Auto-sync MEMORY.md/USER.md/memory/*.md to AgentCore"
      },
      "fileSyncPaths": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["MEMORY.md", "USER.md", "memory/*.md"],
        "description": "Files to sync"
      },
      "maxRetries": {
        "type": "number",
        "default": 3,
        "description": "AWS SDK retry attempts"
      },
      "timeoutMs": {
        "type": "number",
        "default": 10000,
        "description": "Per-request timeout"
      },
      "scopes": {
        "type": "object",
        "properties": {
          "agentAccess": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            },
            "description": "Cross-agent read access (additive — global + self always included)"
          },
          "writeAccess": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            },
            "description": "Cross-agent write access (additive — global + self always included)"
          }
        }
      }
    },
    "required": ["memoryId"]
  }
}
